# Copy this file to backend/.env and fill in real values from Supabase.

SUPABASE_URL=https://your-project-ref.supabase.co

# Use the service role key only in backend scripts.
# Never put this key into frontend code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# This key will be used later by the frontend.
SUPABASE_ANON_KEY=your-anon-key

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-nano

TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
TELEGRAM_SESSION_NAME=yerevan_events
TELEGRAM_CHANNELS=@channel_one,@channel_two
TELEGRAM_FETCH_LIMIT=20
